```gitignore
# ==========================
# Node.js
# ==========================
node_modules/
npm-debug.log*
package-lock.json

# ==========================
# Logs
# ==========================
logs/
*.log
*.log.*

# ==========================
# Reports
# ==========================
allure-results/
allure-report/
reports/
test-results/
wdio-logs/
build/

# ==========================
# Screenshots & Videos
# ==========================
screenshots/
videos/

# ==========================
# Coverage
# ==========================
coverage/
.nyc_output/

# ==========================
# Environment Files
# ==========================
.env
.env.*
!.env.example

# ==========================
# IDE Files
# ==========================
.vscode/
.idea/
*.iml

# ==========================
# macOS
# ==========================
.DS_Store

# ==========================
# Windows
# ==========================
Thumbs.db

# ==========================
# Temporary Files
# ==========================
tmp/
temp/
*.tmp

# ==========================
# Appium
# ==========================
appium.log
*.trace

# ==========================
# Android
# ==========================
*.apk
*.aab

# Uncomment if APKs are downloaded/generated locally
# apps/*.apk

# ==========================
# iOS
# ==========================
DerivedData/
*.ipa

# ==========================
# Test Output
# ==========================
output/
results/

# ==========================
# Cache
# ==========================
.cache/
```
